# Pomodoro Timer Environment Variables
# No required environment variables - all settings have sensible defaults

# App Configuration (optional)
# VITE_APP_TITLE=Pomodoro Focus

# Default Timer Durations (in minutes)
# VITE_DEFAULT_WORK_DURATION=25
# VITE_DEFAULT_BREAK_DURATION=5
# VITE_DEFAULT_LONG_BREAK_DURATION=15

# Feature Flags
# VITE_ENABLE_SOUND=true
# VITE_ENABLE_NOTIFICATIONS=true
